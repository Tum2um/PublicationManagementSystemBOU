# Copy this file to .env only if your process manager loads .env files.
# Django reads environment variables; it does not load this file automatically.

# Local development defaults
DJANGO_DEBUG=true
DJANGO_SECRET_KEY=replace-with-a-long-random-value
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=Lax
SECURE_SSL_REDIRECT=false
SECURE_HSTS_SECONDS=0
SECURE_HSTS_PRELOAD=false

# Used only when setup_local.py creates the local development administrator.
DEV_ADMIN_PASSWORD=replace-with-a-strong-local-password
